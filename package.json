{
  "name": "@wyre-technology/meraki-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Cisco Meraki Dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "meraki-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:ui": "vite build && node scripts/embed-ui.mjs",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "meraki",
    "cisco",
    "mcp",
    "msp",
    "network",
    "model-context-protocol"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "@wyre-technology/node-meraki": "^1.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^25.3.2",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

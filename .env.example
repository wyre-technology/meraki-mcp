# Cisco Meraki Dashboard API key (required)
MERAKI_API_KEY=

# Default organization ID (optional — many tools accept an explicit organization_id)
MERAKI_ORG_ID=

# Override the Meraki API base URL (optional, e.g. a regional shard)
MERAKI_BASE_URL=

# Safety: read-only mode is ON by default. Set to false to allow write operations.
READ_ONLY_MODE=true
